<div class="recommendations-block"
     {% if product and product.id %}
       data-product-id="{{ product.id }}"
       data-url="/recommendations/products.json?product_id={{ product.id }}&limit={{ block.settings.limit }}&intent=related"
       data-layout="{{ block.settings.layout }}"
       data-show-image="{{ block.settings.show_image }}"
       data-limit="{{ block.settings.limit }}"
       data-carousel-items="{{ block.settings.carousel_items }}"
     {% endif %}
>
  <h2>{{ block.settings.heading }}</h2>

  {% unless product and product.id %}
    <p class="rec-message">This block must be added to a product template to show recommendations.</p>
  {% else %}
    <div class="rec-message">Loading recommendations…</div>
    <ul class="rec-grid" hidden></ul>
    <div class="rec-carousel" hidden>
      <button class="rec-prev" aria-label="Previous">‹</button>
      <div class="rec-track-wrapper">
        <ul class="rec-track"></ul>
      </div>
      <button class="rec-next" aria-label="Next">›</button>
    </div>
  {% endunless %}
</div>

<link rel="stylesheet" href="{{ 'recommendations.css' | asset_url }}" />
<script src="{{ 'recommendations.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Recommendations",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recommended for this product"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Display style",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Maximum items",
      "default": 3
    },
    {
      "type": "select",
      "id": "carousel_items",
      "label": "Carousel items per view",
      "options": [
        { "value": "1", "label": "1 item" },
        { "value": "2", "label": "2 items" },
        { "value": "3", "label": "3 items" },
        { "value": "4", "label": "4 items" },
        { "value": "5", "label": "5 items" }
      ],
      "default": "3"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    }
  ]
}
{% endschema %}
